{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "api/src",
    "outDir": "api/dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUncheckedSideEffectImports": true,
    "types": ["node"]
  },
  "include": ["api/src/**/*.ts"],
  "exclude": ["node_modules"]
}
